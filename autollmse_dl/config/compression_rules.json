{
  "MEMORY.md": {
    "keep_sections": ["核心身份", "重要配置", "关键决策", "系统架构", "待关注", "截图方法", "浏览器控制方法", "技能优化记录", "记忆系统回滚状态", "卖家精灵流量词导出任务"],
    "min_importance_score": 7,
    "time_decay_factor": 0.8,
    "max_file_size_kb": 500,
    "preserve_code_blocks": true,
    "encoding": "utf-8",
    "line_ending": "lf"
  },
  "daily_memory": {
    "aggregate_window_days": 7,
    "importance_threshold": 5,
    "event_summarization": true,
    "max_events_per_day": 20,
    "filename_pattern": "memory/{date}.md",
    "preserve_dates": [],
    "encoding": "utf-8",
    "line_ending": "lf"
  },
  "hot_memory": {
    "real_time_dedup": true,
    "emergency_preserve": ["当前任务状态", "关键决策", "下一步行动", "重要变量"],
    "max_size_kb": 100,
    "encoding": "utf-8",
    "line_ending": "lf"
  },
  "unified_summary": {
    "session_limit": 12,
    "message_preview_length": 100,
    "latest_messages_to_keep": 5,
    "encoding": "utf-8",
    "line_ending": "lf"
  },
  "cross_platform": {
    "windows": {
      "path_separator": "\\",
      "encoding": "utf-8-sig",
      "line_ending": "crlf"
    },
    "unix": {
      "path_separator": "/",
      "encoding": "utf-8",
      "line_ending": "lf"
    }
  }
}
